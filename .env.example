PORT=3000
NODE_ENV=development

# Min 32 chars. Used to decrypt vault-encrypted API keys.
MASTER_KEY=your_super_secret_master_key_min_32_chars_long

# Comma-separated client auth tokens (any one is accepted via Bearer / x-api-key).
CLIENT_TOKENS=dev-token-1,dev-token-2

# Provider API keys. Each variable accepts either:
#   - a single key:           GOOGLE_API_KEY=AIzaSy...
#   - multiple keys (comma):  GOOGLE_API_KEY=key1,key2,key3
#   - encrypted strings produced by `npm run vault` (in either form above)
# Multiple keys enable per-key round-robin and per-key cooldowns on 429.
GOOGLE_API_KEY=your_google_api_key_or_comma_separated_list
GROQ_API_KEY=your_groq_api_key_or_comma_separated_list

# Optional: proactive rate-limit gating (per provider, applies to all its models).
# When set, the router skips a provider before sending if its sliding window is full.
# Leave unset to disable gating (failover-on-429 still works).
# GOOGLE_RPM=15
# GOOGLE_RPD=1500
# GROQ_RPM=30
# GROQ_RPD=14400

# Optional observability.
LOG_RETENTION_DAYS=7
GRAFANA_PASSWORD=admin
